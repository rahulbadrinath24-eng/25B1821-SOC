#include <bits/stdc++.h>
using namespace std;
typedef long long ll;

int main(){
  int i,N;
  ll x,sum=0;
  vector<ll> vec;
  cin>>N;
  for(i=0; i<N; i++){
    cin>>x;
    sum+=x;
    vec.push_back(x);
  }
  sort(vec.rbegin(), vec.rend());
  x = 0;
  for(i = 0; i < N; i++) {
     x += vec[i];
      if (x * 2 > sum) {
          i++;
          break;
     }
  }
  cout << i << "\n";
  return 0;
}
