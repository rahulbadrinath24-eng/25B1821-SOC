#include <iostream>
#include <bits/stdc++.h>
using namespace std;
typedef long long ll;

int main(){
  int N;
  cin>>N;
  vector<ll> a,b;
  ll n,k,x;
  for(int i=0; i<N; i++){
    cin>>n>>k;
    for(int j=0; j<n; j++){
      cin>>x;
      a.push_back(x);
    }
    for(int j=0; j<n;j++){
      cin>>x;
      b.push_back(x);
    }
    sort(a.begin(), a.end());
    sort(b.rbegin(), b.rend());
    x=0;
    for(int j=0; j<n; j++){
      if(a[j]<b[j] && k>0){
         a[j] = b[j];
         k--;
      }
      x+=a[j];
    }
    cout<<x<<"\n";
    a.clear();
    b.clear();
  }
  return 0;
}
