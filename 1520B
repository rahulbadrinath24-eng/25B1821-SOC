#include <bits/stdc++.h>
using namespace std;
int main(){
    long long N;
    long long n;
    cin>>N;
    for(int i=0; i<N; i++){
        cin>>n;
        int count=0;
        for(int j=1; j<10; j++){
            long long num=j;
            while(num<=n){
                count++;
                num = num*10 + j;
            }
        }
        cout<<count<<"\n";
    }
    return 0;
}
