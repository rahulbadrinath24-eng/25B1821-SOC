#include <bits/stdc++.h>
using namespace std;
typedef long long ll;

int main(){
  int N;
  cin>>N;
  ll n,k,x;
  vector<ll> vec;
  for(int i=0; i<N; i++){
    cin>>n>>k;
    ll zeros=0;
    for(int j=0; j<n; j++){
      cin>>x;
      if(x%k) vec.push_back(x%k);
      else zeros++;
    }
    if(vec.empty()){
      cout<<"0"<<"\n";
      continue;
    }
    sort(vec.begin(), vec.end());
    x=0;
    ll count,maxcount=0,maxcountval=0;
    int j=0;
    while(j<n-zeros){
      count = 0;
      x = vec[j];
      for(ll y=j; y<n-zeros; y++){
        if(vec[y]==x){
          count++;
        }
        else break;
      }
      j = j + count;
      if(count>maxcount){
        maxcountval = x;
        maxcount = count;
      }
    }
    cout<<(maxcount*k -maxcountval +1)<<"\n";
    vec.clear();
  }
  return 0;
}
